# FenJue Engine — Environment Variables
# ======================================
# 复制此文件为 .env 后填入实际值:
#   cp .env.example .env
#
# Docker Compose 会自动加载同目录下的 .env 文件。

# ---- Runtime ----
FENJUE_ENV=development

# ---- API Keys ----
# 市场数据源 (akshare 无需 key，此处预留扩展)
# AKSHARE_TOKEN=
# TUSHARE_TOKEN=

# ---- Database ----
FENJUE_DB_PATH=data/fenjue.db

# ---- PostgreSQL (未来迁移用) ----
# FENJUE_DB_USER=fenjue
# FENJUE_DB_PASSWORD=fenjue
# FENJUE_DB_NAME=fenjue

# ---- LLM / AI (预留) ----
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
